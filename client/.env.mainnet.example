# Template for client/.env.mainnet. The actual file is generated by
# scripts/deploy_mainnet.sh and committed (after a successful deploy)
# so contributors can run the client against the live world.
#
# No private keys here — players connect with their own Cartridge
# Controller account.

VITE_PUBLIC_DOJO_PROFILE=mainnet
VITE_PUBLIC_NODE_URL=https://api.cartridge.gg/x/starknet/mainnet
VITE_PUBLIC_NAMESPACE=zordle_0_1
VITE_PUBLIC_SLOT=zordle-mainnet
VITE_PUBLIC_CHAIN_ID_NFT=SN_MAIN
VITE_PUBLIC_WORLD_ADDRESS=0x...
VITE_PUBLIC_ACTIONS_ADDRESS=0x...
VITE_PUBLIC_DENSHOKAN_ADDRESS=0x...
VITE_PUBLIC_VRF_ADDRESS=0x051fea4450da9d6aee758bdeba88b2f665bcbf549d2c61421aa724e9ac0ced8f
