# Template for client/.env.sepolia. The actual file is generated by
# scripts/deploy_sepolia.sh and committed (after a successful deploy)
# so contributors can run the client against the live world.
#
# No private keys here — players connect with their own Cartridge
# Controller account.

VITE_PUBLIC_NODE_URL=https://api.cartridge.gg/x/starknet/sepolia
VITE_PUBLIC_NAMESPACE=zordle_0_1
VITE_PUBLIC_SLOT=zordle-sepolia
VITE_PUBLIC_WORLD_ADDRESS=0x...
VITE_PUBLIC_ACTIONS_ADDRESS=0x...
VITE_PUBLIC_DENSHOKAN_ADDRESS=0x0004e6e5bbf18424dfb825f1dbb65e10473b4603a1ec7b9ab02c143d877114f9
VITE_PUBLIC_VRF_ADDRESS=0x051fea4450da9d6aee758bdeba88b2f665bcbf549d2c61421aa724e9ac0ced8f
