# Template for client/.env.sepolia. The actual file is generated by
# scripts/deploy_sepolia.sh and committed (after a successful deploy)
# so that other contributors can run the client against the live world.
#
# WARNING: VITE_PUBLIC_BURNER_PRIVATE_KEY in the real .env.sepolia is the
# deployer's key, shared across every player on the v1 demo. Do not put
# real value at this address.

VITE_PUBLIC_NODE_URL=https://api.cartridge.gg/x/starknet/sepolia
VITE_PUBLIC_BURNER_ADDRESS=0x...
VITE_PUBLIC_BURNER_PRIVATE_KEY=0x...
VITE_PUBLIC_ACTIONS_ADDRESS=0x...
